# LK VISION - Variables de Entorno
# Copia este archivo como ".env" y completa tus valores.

# Google Gemini API Key (obligatoria para la IA de visión)
# Consíguela gratis en https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Modelo de Gemini (por defecto: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# Tasa de cambio CNY -> USD por defecto
CNY_TO_USD_RATE=7.2

# Base de datos (por defecto: SQLite local)
# DATABASE_URL=sqlite:///./lk_vision.db
